# TRIBUTARY Environment Variables
# Copy this file to .env and fill in the values

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Django settings module — use tributary_api.settings.prod for production, tributary_api.settings.dev for local
DJANGO_SETTINGS_MODULE=tributary_api.settings.dev

# PostgreSQL connection string — auto-provided by Render add-on in production
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tributary_dev

# Redis connection string — auto-provided by Render add-on in production
REDIS_URL=redis://localhost:6379

# SendGrid API key — from SendGrid dashboard
SENDGRID_API_KEY=

# Default sender email for transactional emails
DEFAULT_FROM_EMAIL=noreply@upstreamliteracy.org

# Frontend URL — used for CORS and email links
FRONTEND_URL=http://localhost:3000

# Allowed hosts — comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# AWS S3 — Phase 3 only, document now, implement later
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
